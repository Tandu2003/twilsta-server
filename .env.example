PORT=4000
CORS_ORIGIN=http://localhost:3000

DATABASE_URL="postgresql://username:password@localhost:5432/database_name?schema=public"

# JWT Configuration - Replace with secure random strings
JWT_SECRET=your_jwt_secret_here_replace_with_long_random_string
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_replace_with_different_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Environment
NODE_ENV=development
